@page "/members"
@inject IMemberService MemberService
@inject ISiteService SiteService
@inject AdminSessionService SessionService

<PageTitle>Gestion des membres</PageTitle>

<h1>Gestion des membres</h1>

@if (SessionService.IsLoggedIn)
{
    <div class="alert alert-info">
        Connecté en tant que : <strong>@SessionService.CurrentAdmin?.Username</strong> 
        (@SessionService.CurrentAdmin?.Type)
        @if (SessionService.IsSiteAdmin)
        {
            <span> - Site : @SessionService.CurrentAdmin?.SiteName</span>
        }
    </div>
}

@if (errorMessage is not null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}

<div class="row mb-3">
    <div class="col-auto">
        <button class="btn btn-primary" @onclick="ShowCreateForm">Nouveau membre</button>
    </div>
    <div class="col-auto">
        <select class="form-select" @onchange="OnFilterChanged">
            <option value="">Tous les membres</option>
            @if (sites is not null)
            {
                @foreach (var site in sites)
                {
                    <option value="@site.Id">@site.Name</option>
                }
            }
        </select>
    </div>
</div>

@if (showForm)
{
    <div class="card mb-4">
        <div class="card-header">
            @(editingMatricule is not null ? $"Modifier {editingMatricule}" : "Créer un membre")
        </div>
        <div class="card-body">
            @if (editingMatricule is null)
            {
                <EditForm Model="createModel" OnValidSubmit="HandleCreate">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="row mb-3">
                        <div class="col">
                            <label class="form-label">Prénom</label>
                            <InputText class="form-control" @bind-Value="createModel.FirstName" />
                        </div>
                        <div class="col">
                            <label class="form-label">Nom</label>
                            <InputText class="form-control" @bind-Value="createModel.LastName" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <InputText class="form-control" @bind-Value="createModel.Email" />
                    </div>
                    <div class="row mb-3">
                        <div class="col">
                            <label class="form-label">Type</label>
                            <InputSelect class="form-select" @bind-Value="createModel.MemberType" @bind-Value:after="OnMemberTypeChanged">
                                <option value="Global">Global</option>
                                <option value="Site">Site</option>
                                <option value="Libre">Libre</option>
                            </InputSelect>
                        </div>
                        @if (createModel.MemberType == "Site")
                        {
                            <div class="col">
                                <label class="form-label">Site</label>
                                <InputSelect class="form-select" @bind-Value="createSiteIdString">
                                    <option value="">-- Sélectionner --</option>
                                    @if (sites is not null)
                                    {
                                        @foreach (var site in sites)
                                        {
                                            <option value="@site.Id">@site.Name</option>
                                        }
                                    }
                                </InputSelect>
                            </div>
                        }
                    </div>

                    <button type="submit" class="btn btn-success" disabled="@isSubmitting">Créer</button>
                    <button type="button" class="btn btn-secondary ms-2" @onclick="CancelForm">Annuler</button>
                </EditForm>
            }
            else
            {
                <EditForm Model="updateModel" OnValidSubmit="HandleUpdate">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="row mb-3">
                        <div class="col">
                            <label class="form-label">Prénom</label>
                            <InputText class="form-control" @bind-Value="updateModel.FirstName" />
                        </div>
                        <div class="col">
                            <label class="form-label">Nom</label>
                            <InputText class="form-control" @bind-Value="updateModel.LastName" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <InputText class="form-control" @bind-Value="updateModel.Email" />
                    </div>

                    <button type="submit" class="btn btn-success" disabled="@isSubmitting">Mettre à jour</button>
                    <button type="button" class="btn btn-secondary ms-2" @onclick="CancelForm">Annuler</button>
                </EditForm>
            }
        </div>
    </div>
}

@if (members is null)
{
    <p><em>Chargement des membres...</em></p>
}
else if (members.Count == 0)
{
    <p>Aucun membre trouvé.</p>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Matricule</th>
                <th>Nom</th>
                <th>Email</th>
                <th>Type</th>
                <th>Site</th>
                <th>Statut</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var member in members)
            {
                <tr>
                    <td><code>@member.Matricule</code></td>
                    <td>@member.FirstName @member.LastName</td>
                    <td>@member.Email</td>
                    <td>
                        <span class="badge @GetTypeBadgeClass(member.MemberType)">@member.MemberType</span>
                    </td>
                    <td>@(member.SiteName ?? "—")</td>
                    <td>
                        @if (member.ReservationBlocked)
                        {
                            <span class="badge bg-danger">
                                Bloqué@(member.BlockedUntil.HasValue ? $" jusqu'au {member.BlockedUntil.Value:dd/MM/yyyy}" : "")
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-success">Actif</span>
                        }
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ShowEditForm(member)">
                            Modifier
                        </button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteMember(member.Matricule)">
                            Supprimer
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<MemberDto>? members;
    private List<SiteDto>? sites;
    private CreateMemberDto createModel = new();
    private UpdateMemberDto updateModel = new();
    private string? editingMatricule;
    private bool showForm;
    private bool isSubmitting;
    private string? errorMessage;
    private int? filterSiteId;
    private string createSiteIdString = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        sites = await SiteService.GetAllAsync();
        await LoadMembers();
    }

    private async Task LoadMembers()
    {
        try
        {
            var allMembers = filterSiteId.HasValue
                ? await MemberService.GetBySiteIdAsync(filterSiteId.Value)
                : await MemberService.GetAllAsync();

            // Filtrer par site si admin site
            if (SessionService.IsSiteAdmin && SessionService.SiteId.HasValue)
            {
                members = allMembers.Where(m => 
                    m.SiteId == null || m.SiteId == SessionService.SiteId.Value
                ).ToList();
            }
            else
            {
                members = allMembers;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors du chargement des membres : {ex.Message}";
        }
    }

    private async Task OnFilterChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        filterSiteId = string.IsNullOrEmpty(value) ? null : int.Parse(value);
        await LoadMembers();
    }

    private void ShowCreateForm()
    {
        editingMatricule = null;
        createModel = new CreateMemberDto();
        createSiteIdString = string.Empty;
        showForm = true;
    }

    private void ShowEditForm(MemberDto member)
    {
        editingMatricule = member.Matricule;
        updateModel = new UpdateMemberDto
        {
            FirstName = member.FirstName,
            LastName = member.LastName,
            Email = member.Email
        };
        showForm = true;
    }

    private void CancelForm()
    {
        showForm = false;
        editingMatricule = null;
    }

    private void OnMemberTypeChanged()
    {
        if (createModel.MemberType != "Site")
        {
            createModel.SiteId = null;
            createSiteIdString = string.Empty;
        }
    }

    private async Task HandleCreate()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            if (!string.IsNullOrEmpty(createSiteIdString))
                createModel.SiteId = int.Parse(createSiteIdString);
            else
                createModel.SiteId = null;

            var result = await MemberService.CreateAsync(createModel);
            if (result is null)
            {
                errorMessage = "Erreur lors de la création du membre. Vérifiez les données.";
                return;
            }

            CancelForm();
            await LoadMembers();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur : {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task HandleUpdate()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            var result = await MemberService.UpdateAsync(editingMatricule!, updateModel);
            if (result is null)
            {
                errorMessage = "Erreur lors de la mise à jour du membre.";
                return;
            }

            CancelForm();
            await LoadMembers();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur : {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task DeleteMember(string matricule)
    {
        errorMessage = null;

        try
        {
            var success = await MemberService.DeleteAsync(matricule);
            if (!success)
            {
                errorMessage = "Erreur lors de la suppression du membre.";
                return;
            }

            await LoadMembers();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur : {ex.Message}";
        }
    }

    private static string GetTypeBadgeClass(string memberType) => memberType switch
    {
        "Global" => "bg-primary",
        "Site" => "bg-info text-dark",
        "Libre" => "bg-secondary",
        _ => "bg-dark"
    };
}
