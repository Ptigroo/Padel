@page "/sites"
@inject ISiteService SiteService
@inject ICourtService CourtService
@inject IScheduleService ScheduleService

<PageTitle>Gestion des sites</PageTitle>

<h1>Gestion des sites</h1>

@if (errorMessage is not null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}

<div class="mb-3">
    <button class="btn btn-primary" @onclick="ShowCreateForm">
        <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Nouveau site
    </button>
</div>

@if (showForm)
{
    <div class="card mb-4">
        <div class="card-header">
            @(editingSiteId.HasValue ? "Modifier le site" : "Créer un site")
        </div>
        <div class="card-body">
            <EditForm Model="formModel" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label for="name" class="form-label">Nom</label>
                    <InputText id="name" class="form-control" @bind-Value="formModel.Name" />
                </div>
                <div class="mb-3">
                    <label for="address" class="form-label">Adresse</label>
                    <InputText id="address" class="form-control" @bind-Value="formModel.Address" />
                </div>

                <button type="submit" class="btn btn-success" disabled="@isSubmitting">
                    @(editingSiteId.HasValue ? "Mettre à jour" : "Créer")
                </button>
                <button type="button" class="btn btn-secondary ms-2" @onclick="CancelForm">Annuler</button>
            </EditForm>
        </div>
    </div>
}

@if (sites is null)
{
    <p><em>Chargement des sites...</em></p>
}
else if (sites.Count == 0)
{
    <p>Aucun site trouvé.</p>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Adresse</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var site in sites)
            {
                <tr class="@(selectedSiteId == site.Id ? "table-active" : "")">
                    <td>@site.Id</td>
                    <td>@site.Name</td>
                    <td>@site.Address</td>
                    <td>
                        <button class="btn btn-sm btn-outline-info me-1" @onclick='() => SelectSite(site, "courts")'>
                            Terrains
                        </button>
                        <button class="btn btn-sm btn-outline-warning me-1" @onclick='() => SelectSite(site, "schedules")'>
                            Horaires
                        </button>
                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ShowEditForm(site)">
                            Modifier
                        </button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteSite(site.Id)">
                            Supprimer
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@* ── Section terrains du site sélectionné ── *@
@if (selectedSite is not null && activeTab == "courts")
{
    <hr />
    <h3>Terrains — @selectedSite.Name</h3>

    <div class="mb-3">
        <EditForm Model="courtFormModel" OnValidSubmit="HandleCourtSubmit" class="row g-2 align-items-end">
            <DataAnnotationsValidator />
            <div class="col-auto">
                <label for="courtName" class="form-label">Nom du terrain</label>
                <InputText id="courtName" class="form-control" @bind-Value="courtFormModel.Name" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-success">Ajouter</button>
            </div>
            <div class="col-12">
                <ValidationSummary />
            </div>
        </EditForm>
    </div>

    @if (courts is null)
    {
        <p><em>Chargement des terrains...</em></p>
    }
    else if (courts.Count == 0)
    {
        <p>Aucun terrain pour ce site.</p>
    }
    else
    {
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Nom</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var court in courts)
                {
                    <tr>
                        <td>@court.Id</td>
                        <td>@court.Name</td>
                        <td>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteCourt(court.Id)">
                                Supprimer
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@* ── Section horaires du site sélectionné ── *@
@if (selectedSite is not null && activeTab == "schedules")
{
    <hr />
    <h3>Horaires — @selectedSite.Name</h3>

    <div class="mb-3">
        <EditForm Model="scheduleFormModel" OnValidSubmit="HandleScheduleSubmit" class="row g-2 align-items-end">
            <DataAnnotationsValidator />
            <div class="col-auto">
                <label for="scheduleYear" class="form-label">Année</label>
                <InputNumber id="scheduleYear" class="form-control" @bind-Value="scheduleFormModel.Year" />
            </div>
            <div class="col-auto">
                <label for="scheduleStart" class="form-label">Début</label>
                <InputText id="scheduleStart" type="time" class="form-control" @bind-Value="scheduleFormModel.StartTime" />
            </div>
            <div class="col-auto">
                <label for="scheduleEnd" class="form-label">Fin</label>
                <InputText id="scheduleEnd" type="time" class="form-control" @bind-Value="scheduleFormModel.EndTime" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-success">Ajouter</button>
            </div>
            <div class="col-12">
                <ValidationSummary />
            </div>
        </EditForm>
    </div>

    @if (schedules is null)
    {
        <p><em>Chargement des horaires...</em></p>
    }
    else if (schedules.Count == 0)
    {
        <p>Aucun horaire défini pour ce site.</p>
    }
    else
    {
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Année</th>
                    <th>Début</th>
                    <th>Fin</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var schedule in schedules)
                {
                    <tr>
                        <td>@schedule.Year</td>
                        <td>@schedule.StartTime</td>
                        <td>@schedule.EndTime</td>
                        <td>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteSchedule(schedule.Id)">
                                Supprimer
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private List<SiteDto>? sites;
    private CreateSiteDto formModel = new();
    private int? editingSiteId;
    private bool showForm;
    private bool isSubmitting;
    private string? errorMessage;

    // Courts
    private SiteDto? selectedSite;
    private int? selectedSiteId;
    private string activeTab = "courts";
    private List<CourtDto>? courts;
    private CreateCourtDto courtFormModel = new();

    // Schedules
    private List<SiteScheduleDto>? schedules;
    private CreateSiteScheduleDto scheduleFormModel = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadSites();
    }

    private async Task LoadSites()
    {
        try
        {
            sites = await SiteService.GetAllAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors du chargement des sites : {ex.Message}";
        }
    }

    private void ShowCreateForm()
    {
        editingSiteId = null;
        formModel = new CreateSiteDto();
        showForm = true;
    }

    private void ShowEditForm(SiteDto site)
    {
        editingSiteId = site.Id;
        formModel = new CreateSiteDto { Name = site.Name, Address = site.Address };
        showForm = true;
    }

    private void CancelForm()
    {
        showForm = false;
        editingSiteId = null;
        formModel = new CreateSiteDto();
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            if (editingSiteId.HasValue)
            {
                var updateDto = new UpdateSiteDto { Name = formModel.Name, Address = formModel.Address };
                var result = await SiteService.UpdateAsync(editingSiteId.Value, updateDto);
                if (result is null)
                {
                    errorMessage = "Erreur lors de la mise à jour du site.";
                    return;
                }
            }
            else
            {
                var result = await SiteService.CreateAsync(formModel);
                if (result is null)
                {
                    errorMessage = "Erreur lors de la création du site.";
                    return;
                }
            }

            CancelForm();
            await LoadSites();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur : {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task DeleteSite(int id)
    {
        errorMessage = null;

        try
        {
            var success = await SiteService.DeleteAsync(id);
            if (!success)
            {
                errorMessage = "Erreur lors de la suppression du site.";
                return;
            }

            if (selectedSiteId == id)
            {
                selectedSite = null;
                selectedSiteId = null;
                courts = null;
                schedules = null;
            }

            await LoadSites();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur : {ex.Message}";
        }
    }

    // ── Courts ──

    private async Task SelectSite(SiteDto site, string tab)
    {
        selectedSite = site;
        selectedSiteId = site.Id;
        activeTab = tab;
        courtFormModel = new CreateCourtDto { SiteId = site.Id };
        scheduleFormModel = new CreateSiteScheduleDto { SiteId = site.Id };

        if (tab == "courts")
            await LoadCourts();
        else if (tab == "schedules")
            await LoadSchedules();
    }

    private async Task LoadCourts()
    {
        if (selectedSiteId is null) return;

        try
        {
            courts = await CourtService.GetBySiteIdAsync(selectedSiteId.Value);
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors du chargement des terrains : {ex.Message}";
        }
    }

    private async Task HandleCourtSubmit()
    {
        errorMessage = null;

        try
        {
            courtFormModel.SiteId = selectedSiteId!.Value;
            var result = await CourtService.CreateAsync(courtFormModel);
            if (result is null)
            {
                errorMessage = "Erreur lors de la création du terrain.";
                return;
            }

            courtFormModel = new CreateCourtDto { SiteId = selectedSiteId.Value };
            await LoadCourts();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur : {ex.Message}";
        }
    }

    private async Task DeleteCourt(int id)
    {
        errorMessage = null;

        try
        {
            var success = await CourtService.DeleteAsync(id);
            if (!success)
            {
                errorMessage = "Erreur lors de la suppression du terrain.";
                return;
            }

            await LoadCourts();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur : {ex.Message}";
        }
    }

    // ── Schedules ──

    private async Task LoadSchedules()
    {
        if (selectedSiteId is null) return;

        try
        {
            schedules = await ScheduleService.GetBySiteIdAsync(selectedSiteId.Value);
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors du chargement des horaires : {ex.Message}";
        }
    }

    private async Task HandleScheduleSubmit()
    {
        errorMessage = null;

        try
        {
            scheduleFormModel.SiteId = selectedSiteId!.Value;
            var result = await ScheduleService.CreateAsync(scheduleFormModel);
            if (result is null)
            {
                errorMessage = "Erreur lors de la création de l'horaire. Vérifiez qu'il n'existe pas déjà pour cette année.";
                return;
            }

            scheduleFormModel = new CreateSiteScheduleDto { SiteId = selectedSiteId.Value };
            await LoadSchedules();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur : {ex.Message}";
        }
    }

    private async Task DeleteSchedule(int id)
    {
        errorMessage = null;

        try
        {
            var success = await ScheduleService.DeleteAsync(id);
            if (!success)
            {
                errorMessage = "Erreur lors de la suppression de l'horaire.";
                return;
            }

            await LoadSchedules();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur : {ex.Message}";
        }
    }
}
