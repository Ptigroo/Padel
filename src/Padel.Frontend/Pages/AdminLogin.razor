@page "/admin/login"
@using System.ComponentModel.DataAnnotations
@inject IAdministratorService AdministratorService
@inject AdminSessionService SessionService
@inject NavigationManager Navigation

<PageTitle>Connexion administrateur</PageTitle>

<h1>Connexion administrateur</h1>

@if (errorMessage is not null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}

@if (SessionService.IsLoggedIn)
{
    <div class="alert alert-success">
        <h4>Connecté en tant que : @SessionService.CurrentAdmin?.FirstName @SessionService.CurrentAdmin?.LastName</h4>
        <p><strong>Username :</strong> @SessionService.CurrentAdmin?.Username</p>
        <p><strong>Type :</strong> @SessionService.CurrentAdmin?.Type</p>
        @if (SessionService.CurrentAdmin?.SiteName is not null)
        {
            <p><strong>Site :</strong> @SessionService.CurrentAdmin.SiteName</p>
        }
        <button class="btn btn-warning" @onclick="Logout">Déconnexion</button>
    </div>
}
else
{
    <div class="card" style="max-width: 500px;">
        <div class="card-body">
            <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label for="username" class="form-label">Username administrateur</label>
                    <InputText id="username" class="form-control" @bind-Value="loginModel.Username" placeholder="AG0001 ou AS00001" />
                </div>

                <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                    @(isSubmitting ? "Connexion..." : "Se connecter")
                </button>
            </EditForm>
        </div>
    </div>

    <div class="mt-4 alert alert-info">
        <h5>Administrateurs de démonstration :</h5>
        <p><strong>Admin Global :</strong> AG0001, AG0002</p>
        <p><strong>Admin Site Bruxelles :</strong> AS00001</p>
        <p><strong>Admin Site Liège :</strong> AS00002</p>
        <p><strong>Admin Site Namur :</strong> AS00003</p>
    </div>
}

@code {
    private LoginModel loginModel = new();
    private string? errorMessage;
    private bool isSubmitting;

    private async Task HandleLogin()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            var admin = await AdministratorService.GetByUsernameAsync(loginModel.Username);
            if (admin == null)
            {
                errorMessage = $"Administrateur avec le username '{loginModel.Username}' introuvable.";
            }
            else
            {
                SessionService.Login(admin);
                Navigation.NavigateTo("/sites");
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors de la connexion : {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Logout()
    {
        SessionService.Logout();
        loginModel = new LoginModel();
    }

    public class LoginModel
    {
        [Required(ErrorMessage = "Le username est requis")]
        public string Username { get; set; } = "";
    }
}
