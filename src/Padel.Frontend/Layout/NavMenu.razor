@inject Services.AdminSessionService AdminSession
@implements IDisposable

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Padel Manager</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Accueil
            </NavLink>
        </div>

        <h6 class="px-3 mt-3 text-muted">JOUEUR</h6>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="reservations">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Réservation
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="matches/public">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Matchs publics
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="my-matches">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Mes matchs
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="my-payments">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Mes paiements
            </NavLink>
        </div>

        @if (AdminSession.IsLoggedIn)
        {
            <h6 class="px-3 mt-3 text-muted">ADMINISTRATION</h6>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="sites">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Sites
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="members">
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Membres
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin/matches">
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Tous les matchs
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="stats">
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Statistiques
                </NavLink>
            </div>
        }
        else
        {
            <h6 class="px-3 mt-3 text-muted">ADMINISTRATION</h6>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin/login">
                    <span class="bi bi-person-fill-nav-menu" aria-hidden="true"></span> Connexion Admin
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    protected override void OnInitialized()
    {
        // S'abonner aux changements de session admin
        AdminSession.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        // Se désabonner pour éviter les fuites mémoire
        AdminSession.OnChange -= StateHasChanged;
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
